___SANDBOXED_JS_FOR_WEB_TEMPLATE___

const log = require('logToConsole');
const Object = require('Object');
const callInWindow = require('callInWindow');
const injectScript = require('injectScript');
const makeTableMap = require('makeTableMap');
const isConsentGranted = require('isConsentGranted');

/* Layerguard Library Source*/
const lib = 'https://libs.layerguard.io/sdk.js';
const tag_action = data.action;

const normalize = val => {
  if (val === true || val === 'true') return true;
  if (val === false || val === 'false') return false;
  return val;
};

const init = () => {
  callInWindow('_layerguard.init', {
    stream_id: data.stream_id,
    consent_status: normalize(isConsentGranted('analytics_storage')),
    debug_mode: data.debug,
    filter_known_bots: !data.filter_known_bots,
    flag_malicious_bots: data.flag_malicious_bots,
    bot_threshold: data.bot_threshold,
    anonymize: data.anonymizeTerms ? data.anonymizeTerms.split(',').map(term => term.trim()) : []
  });
};

const sendEvent = () => {
  const eventObject = data.sharedParamsList ? data.sharedParamsList : {};
  if(data.customParamsList && data.customParamsList.length){
      for(var x=0; x < data.customParamsList.length; x++){
        eventObject[data.customParamsList[x].key] = data.customParamsList[x].value;
      }
  }
  eventObject.event = data.event_name;

  callInWindow('_layerguard.push', data.layerguard_event_model ,eventObject);
};

const update = () => {
  
  const updateObject = {
    consent_status: isConsentGranted('analytics_storage'),
    spa_mode: data.spa_website,
    page: data.page_update_params && data.page_update_params.length ? makeTableMap(data.page_update_params, 'name', 'value') : {}
  };

  callInWindow('_layerguard.update', updateObject);
};

const onSuccess = () => {  
  if(data.action == 'load'){
    init();
  } else if(data.action == 'send'){
    sendEvent();
  }else if(data.action == 'update') {
    update();
  }
  data.gtmOnSuccess();
};

const onFailure = () => {
  log('Failed to load the LayerGuard SDK.');
  data.gtmOnFailure();
};

injectScript(lib, onSuccess, onFailure, 'LayerGuard');


